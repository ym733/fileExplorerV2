<%= turbo_frame_tag "file-grid", class: "file-grid" do %>
<% if @is_text %>
<div class="file-grid" id="file-grid">
    <textarea id="text-input" name="text-input"><%= @text %></textarea>
</div>

<script>
    async function func() {
        <% @language[:files].each do |item| %>
            await import("modules/<%= item[0...-3] %>");
        <% end %>

        editor = CodeMirror.fromTextArea(document.getElementById('text-input'), {
            mode: '<%= @language[:mode] %>',
            lineNumbers: true,
            autoCloseBrackets: true,
            matchBrackets: true,
            foldGutter: true,
            styleActiveLine: true,
            gutters: ["CodeMirror-linenumbers", "CodeMirror-foldgutter"],
        });
    }

    func();
</script>

<script>
    document.getElementById('save-button').style.display = 'flex';
    document.getElementById('refresh-file').style.display = 'block';
    document.getElementById('upload-file').style.display = 'none';
    document.getElementById('create-file').style.display = 'none';
    document.getElementById('create-folder').style.display = 'none';

    document.addEventListener('keydown', function(event) {
        if (event.ctrlKey && event.key === 's') {
            event.preventDefault(); // Prevent the default browser save dialog
            if (canSave) {
                saveData();

                // Disable for 1 second
                canSave = false;
                setTimeout(() => {
                    canSave = true;
                }, 1000);
            }
        }
    });

    function saveData() {
        const itemPath = '<%= @item_path %>';
        const textData = editor.getValue();

        fetch('/save', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
                },
                body: JSON.stringify({
                    item_path: itemPath,
                    text_data: textData
                })
            }).then(response =>
                response.json())
            .then(data => {
                if (data.error) {
                    showNotification(data.error, 'error');
                } else {
                    showNotification(data.message, 'success');
                }

            });
    }
</script>

<% else %>
<div class="file-grid" id="file-grid">
  <div class="d-flex justify-content-center flex-column align-items-center" style="margin:auto">
    <% if @image %>
    <div id="zi">
        <img src="data:image/<%= @extension.downcase %>;base64,<%= @image %>" style="max-height:80vh;cursor:zoom-in" onclick="document.getElementById('zo').classList.remove('hidden')">
        <div id="zo" class="hidden" style="position:fixed;inset:0;background:#000000d9;display:flex;align-items:center;justify-content:center;z-index:1000;cursor:zoom-out">
            <div id="zj">
                <img src="data:image/<%= @extension.downcase %>;base64,<%= @image %>" style="max-width:90vw;max-height:90vh;object-fit:contain">
            </div>
        </div>
    </div>

    <script>
        var zj = document.getElementById('zj');
        var zo = document.getElementById('zo');
        var scale = 1, x = 0, y = 0, dragging = false, startX, startY;

        zj.querySelector('img').addEventListener('dragstart', e => e.preventDefault());

        zo.addEventListener('wheel', function(e) {
            e.preventDefault();
            scale = Math.min(Math.max(scale + (e.deltaY < 0 ? 0.1 : -0.1), 0.5), 5);
            zj.style.transform = `scale(${scale}) translate(${x}px, ${y}px)`;
        }, { passive: false });

        zj.addEventListener('mousedown', function(e) {
            e.stopPropagation();
            dragging = true;
            startX = e.clientX - x;
            startY = e.clientY - y;
            zj.style.cursor = 'grabbing';
        });

        window.addEventListener('mousemove', function(e) {
            if (!dragging) return;
            x = e.clientX - startX;
            y = e.clientY - startY;
            zj.style.transform = `scale(${scale}) translate(${x}px, ${y}px)`;
        });

        window.addEventListener('mouseup', function() {
            dragging = false;
            zj.style.cursor = 'grab';
        });

        zo.addEventListener('click', function(e) {
            if (e.target === zo) {
                scale = 1; x = 0; y = 0;
                zj.style.transform = 'scale(1) translate(0, 0)';
                this.classList.add('hidden');
            }
        });
    </script>
            
    <% else %>
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mb-2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14,2 14,8 20,8"/>
        <line x1="9" y1="11.5" x2="15" y2="17.5"/><line x1="15" y1="11.5" x2="9" y2="17.5"/>
    </svg>
    <span>The file is not displayed because it is either binary or uses an unsupported text encoding.</span>
    <% end %>
  </div>
</div>

<script>
  ['save-button','upload-file','create-file','create-folder'].forEach(id => document.getElementById(id).style.display = 'none');
</script>
<% end %>
<% end %>