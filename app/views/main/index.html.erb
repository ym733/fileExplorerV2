<div class="file-explorer-container">
    <!-- Sidebar for directory tree -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h3>Directory Tree</h3>
            <button type="button" id="refresh-tree" onclick="refreshDirectoryTree('<%= @root_directory_path %>', this.parentElement.nextElementSibling.querySelector('li.directory > ul'));" class="btn btn-outline-secondary btn-sm"><i class="fas fa-sync-alt"></i></button>
        </div>

        <div class="directory-tree" id="directory-tree">
            <!-- Directory tree will be populated here -->
            <ul class="directory-tree">
                <li class="directory" style="list-style-type: none;">
                    <svg class="clickable-arrow" width="12" height="12" viewBox="0 0 12 12" onclick="toggleListItems('<%= @root_directory_path %>', this.parentElement.querySelector('ul')); toggleArrow(this);">
                        <path d="M4 2 L8 6 L4 10" stroke="#8a8a8a" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>

                    <%= button_to "Root",
                        "/folder",
                        method: :get,
                        params: { item_path: @root_directory_path },
                        class: "btn btn-plain-text name text-nowrap",
                        form: { data: { turbo_frame: "file-grid" } }
                    %>
                    <ul class="directory-tree" id="root-directory-list"></ul>
                </li>
            </ul>
        </div>
    </div>

    <!-- Main content area -->
    <div class="main-content">
        <div class="toolbar">
            <div class="toolbar-actions-l d-flex">
                <button class="btn btn-outline-secondary btn-sm" id="toggle-sidebar" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="ms-auto" id="back-button-div">
                    <%= button_to raw('<i class="fa-solid fa-angle-left fa-lg"></i>'),
                        "/back",
                        method: :get,
                        class: "btn btn-outline-info btn-sm",
                        form: { data: { turbo_frame: "file-grid" } }
                    %>
                </div>
                <button class="btn btn-outline-secondary btn-sm" id="create-folder" style="display:none;">
                    <i class="fas fa-folder-plus"></i> New Folder
                </button>
                <button class="btn btn-outline-secondary btn-sm" id="create-file" style="display:none;">
                    <i class="fa-solid fa-file-circle-plus"></i> New File
                </button>
                <button class="btn btn-outline-secondary btn-sm" id="upload-file" style="display:none;">
                    <i class="fas fa-upload"></i> Upload
                </button>
            </div>
            <div class="toolbar-actions-r d-flex">
                <%= button_to raw('<i class="fas fa-sync-alt"></i>'),
                    "/refresh_file",
                    method: :get,
                    id: "refresh-file",
                    class: "btn btn-outline-secondary btn-sm",
                    style: "display: none;",
                    form: { data: { turbo_frame: "file-grid" } } 
                %>
                <div id="save-button-div">
                    <button id="save-button" class="btn btn-outline-info btn-sm h-100 align-items-center justify-content-center" onclick="saveData()" style="display:none;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-floppy" viewBox="0 0 16 16">
                            <path d="M11 2H9v3h2z" />
                            <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v4.5A1.5 1.5 0 0 1 11.5 7h-7A1.5 1.5 0 0 1 3 5.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>


        <%= turbo_frame_tag "file-grid", class: "file-grid" do %>
        <!-- Files and folders will be populated here -->
        <div class="empty-state" style="margin: auto;">
            <i class="fas fa-folder-open fa-5x text-themed-muted"></i>
            <h4>This folder is empty</h4>
            <p>Upload files or create new folders to get started.</p>
        </div>
        <% end %>
    </div>
</div>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        sidebar.classList.toggle('collapsed');
    }

    function toggleListItems(path, ul_element) {
        if (ul_element.hasChildNodes()) {
            while (ul_element.firstChild) {
                ul_element.removeChild(ul_element.firstChild);
            }
        } else {
            if (ul_element) {
                ul_element.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span><span> Retrieving chrildren </span>`
            }

            fetch(`/children?item_path=${encodeURIComponent(path)}`, {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
                    }
                })
                .then(response => response.text())
                .then(html => {
                    if (ul_element) {
                        ul_element.outerHTML = html;
                    }
                })
                .catch(error => {
                    showNotification("Failed to retireive children.", 'error');
                    console.error('Error:', error)
                });
        }
    }

    function refreshDirectoryTree(path, ul_element) {
        while (ul_element.firstChild) {
            ul_element.removeChild(ul_element.firstChild);
        }

        if (ul_element) {
            ul_element.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span><span> Retrieving chrildren </span>`
        }

        fetch(`/children?item_path=${encodeURIComponent(path)}`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
                }
            })
            .then(response => response.text())
            .then(html => {
                if (ul_element) {
                    html.id = "root-directory-list";
                    console.log(html.id);
                    console.log(html)
                    ul_element.outerHTML = html;
                }
            })
            .catch(error => {
                showNotification("Failed to retireive children.", 'error');
                console.error('Error:', error)
            });
    }

    function toggleArrow(svg) {
        const isDown = svg.dataset.down === 'true';
        svg.dataset.down = !isDown;
        svg.style.transform = isDown ? 'rotate(0deg)' : 'rotate(90deg)';
    }

    // Function to show notification
    function showNotification(message, type) {
        // Remove any existing notification
        let existingNotification = document.querySelector('[data-notification="true"]');
        if (existingNotification) {
            existingNotification.remove();
        }

        // Create notification element
        const notification = document.createElement('div');
        notification.setAttribute('data-notification', 'true');
        notification.textContent = message;

        // Set styles individually to avoid any parsing issues
        notification.style.position = 'fixed';
        notification.style.bottom = '20px';
        notification.style.left = '50%';
        notification.style.transform = 'translateX(-50%)';
        notification.style.padding = '12px 20px';
        notification.style.borderRadius = '6px';
        notification.style.color = 'white';
        notification.style.fontWeight = '500';
        notification.style.boxShadow = '0 4px 12px rgba(0, 0, 0, 0.15)';
        notification.style.zIndex = '1000';
        notification.style.minWidth = '200px';
        notification.style.textAlign = 'center';
        notification.style.opacity = '0';
        notification.style.transition = 'all 0.3s ease';
        notification.style.backgroundColor = type === 'error' ? '#ef4444' : '#10b981';

        // Add to page
        document.body.appendChild(notification);

        // Show notification
        setTimeout(function() {
            notification.style.opacity = '1';
        }, 10);

        // Hide after 4 seconds
        setTimeout(function() {
            notification.style.opacity = '0';
            setTimeout(function() {
                if (notification.parentNode) {
                    notification.parentNode.removeChild(notification);
                }
            }, 300);
        }, 4000);
    }

    let canSave = true;
    let editor = null;
</script>


<script>
    // THIS IS THE /new_file IMPLMENTATION

    document.getElementById('create-folder').addEventListener('click', function() {
        this.disabled = true;
        showCreateDialog('folder');
        setTimeout(() => this.disabled = false, 300);
    });

    document.getElementById('create-file').addEventListener('click', function() {
        this.disabled = true;
        showCreateDialog('file');
        setTimeout(() => this.disabled = false, 300);
    });

    function showCreateDialog(type) {
        const modal = document.createElement('div');
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';

        modal.innerHTML = `
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border-color);">
                <div class="modal-header" style="border-color: var(--border-color);">
                    <h5 class="modal-title">Create New ${type === 'folder' ? 'Folder' : 'File'}</h5>
                    <button type="button" class="btn-close" data-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" class="form-control" id="item-name" 
                           placeholder="Enter ${type} name" 
                           style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: var(--border-color);">
                </div>
                <div class="modal-footer" style="border-color: var(--border-color);">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="confirm-create">Create</button>
                </div>
            </div>
        </div>`;

        document.body.appendChild(modal);
        document.getElementById('item-name').focus();

        const closeModal = () => {
            modal.remove();
        };

        modal.querySelectorAll('[data-dismiss="modal"]').forEach(btn => {
            btn.addEventListener('click', closeModal);
        });

        document.getElementById('confirm-create').addEventListener('click', function() {
            const name = document.getElementById('item-name').value.trim();
            if (name) {
                createItem(type, name);
                closeModal();
            }
        });

        document.getElementById('item-name').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const name = this.value.trim();
                if (name) {
                    createItem(type, name);
                    closeModal();
                }
            }
        });
    }

    function createItem(type, name) {
        fetch('/new_file', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
                },
                body: JSON.stringify({
                    item_type: type,
                    name: name
                })
            })
            .then(response => response.text())
            .then(html => {
                const fileGrid = document.getElementById('file-grid');
                if (fileGrid) {
                    fileGrid.outerHTML = html;
                }
                showNotification(`Item created successfully.`, 'success');
            })
            .catch(error => {
                showNotification("Failed to create item.", 'error');
                console.error('Error:', error)
            });
    }
</script>

<script>
    // THIS IS THE /upload IMPLMENTATION

    document.getElementById('upload-file').addEventListener('click', function() {
        this.disabled = true;
        showUploadDialog();
        setTimeout(() => this.disabled = false, 300);
    });

    function showUploadDialog() {

        console.log("upload file")

        const modal = document.createElement('div');
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';

        modal.innerHTML = `
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border-color);">
                <div class="modal-header" style="border-color: var(--border-color);">
                    <h5 class="modal-title">Upload File</h5>
                    <button type="button" class="btn-close" data-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="file" class="form-control" id="file-input" 
                           style="background-color: var(--bg-secondary); color: var(--text-primary); border-color: var(--border-color);">
                </div>
                <div class="modal-footer" style="border-color: var(--border-color);">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="confirm-upload">Upload</button>
                </div>
            </div>
        </div>`;

        document.body.appendChild(modal);

        const closeModal = () => {
            modal.remove();
        };

        modal.querySelectorAll('[data-dismiss="modal"]').forEach(btn => {
            btn.addEventListener('click', closeModal);
        });

        document.getElementById('confirm-upload').addEventListener('click', function() {
            const fileInput = document.getElementById('file-input');
            const file = fileInput.files[0];
            if (file) {
                uploadFile(file);
                closeModal();
            }
        });
    }

    function uploadFile(file) {
        const formData = new FormData();
        formData.append('file', file);

        fetch('/upload', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
                },
                body: formData
            })
            .then(response => response.text())
            .then(html => {
                const fileGrid = document.getElementById('file-grid');
                if (fileGrid) {
                    fileGrid.outerHTML = html;
                }
                showNotification(`Item uploaded successfully.`, 'success');
            })
            .catch(error => {
                showNotification("Failed to upload item.", 'error');
                console.error('Error:', error)
            });
    }
</script>

<script>
    // THIS IS THE /delete_file IMPLMENTATION

    function delete_file(item_path) {
        const modal = document.createElement('div');
        modal.className = 'modal fade show';
        modal.style.display = 'block';
        modal.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';

        modal.innerHTML = `
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: var(--bg-primary); color: var(--text-primary); border-color: var(--border-color);">
                <div class="modal-header" style="border-color: var(--border-color);">
                    <h5 class="modal-title">Delete Item</h5>
                    <button type="button" class="btn-close" data-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this item?</p>
                    <p style="color: var(--text-secondary); font-size: 0.9em;">${item_path}</p>
                </div>
                <div class="modal-footer" style="border-color: var(--border-color);">
                    <button type="button" class="btn btn-danger" id="confirm-delete">Delete</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    `;

        document.body.appendChild(modal);

        const closeModal = () => {
            modal.remove();
        };

        modal.querySelectorAll('[data-dismiss="modal"]').forEach(btn => {
            btn.addEventListener('click', closeModal);
        });

        document.getElementById('confirm-delete').addEventListener('click', function() {
            fetch('/delete_file', {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
                    },
                    body: JSON.stringify({
                        item_path: item_path
                    })
                })
                .then(response => response.text())
                .then(html => {
                    const fileGrid = document.getElementById('file-grid');
                    if (fileGrid) {
                        fileGrid.outerHTML = html;
                    }
                    closeModal();
                    showNotification(`Item deleted successfully.`, 'success');
                })
                .catch(error => {
                    showNotification("Failed to delete item.", 'error');
                    console.error('Error:', error)
                });
        });
    }
</script>