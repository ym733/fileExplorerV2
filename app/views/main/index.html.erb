<div class="file-explorer-container">
    <!-- Sidebar for directory tree -->
    <div class="sidebar">
        <div class="sidebar-header">
            <h3>Directory Tree</h3>
            <button class="btn btn-sm btn-outline-secondary" id="refresh-tree">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
        </div>

        <div class="directory-tree" id="directory-tree">
            <!-- Directory tree will be populated here -->
            <ul class="directory-tree">
                <li class="directory">
                    <!-- <span class="name text-nowrap">Root</span> -->
                    <button class="btn btn-plain-text name text-nowrap" onclick="toggleListItems('<%= Dir.pwd.gsub('/', '_') %>')">Root</button>
                    <%= render "shared/directory_tree", tree: @tree, id: Dir.pwd.gsub('/', '_') %>
                </li>
            </ul>
        </div>
    </div>

    <!-- Main content area -->
    <div class="main-content">
        <div class="toolbar">
            <div class="toolbar-actions">
                <button class="btn btn-outline-primary btn-sm" id="create-folder">
                    <i class="fas fa-folder-plus"></i> New Folder
                </button>
                <button class="btn btn-outline-success btn-sm" id="upload-file">
                    <i class="fas fa-upload"></i> Upload
                </button>
            </div>
        </div>

        <div class="file-grid" id="file-grid">
            <!-- Files and folders will be populated here -->
            <div class="empty-state">
                <i class="fas fa-folder-open fa-5x text-themed-muted"></i>
                <h4>This folder is empty</h4>
                <p>Upload files or create new folders to get started.</p>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleListItems(id) {
        const items = document.querySelectorAll(`#${id} > li`);
        items.forEach(item => {
            item.style.display = (item.style.display === "none") ? "list-item" : "none";
        });
    }
</script>