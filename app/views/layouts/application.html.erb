<!DOCTYPE html>
<html>

<head>
    <title><%= content_for(:title) || "File Explorer V2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

    <style>
        .file-explorer-container {
            display: flex;
            height: calc(100vh - 60px);
            background-color: #f8f9fa;
        }

        .sidebar {
            width: 300px;
            background-color: white;
            border-right: 1px solid #dee2e6;
            padding: 1rem;
            overflow-y: auto;
        }

        .sidebar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid #dee2e6;
        }

        .sidebar-header h3 {
            margin: 0;
            font-size: 1.2rem;
            color: #495057;
        }

        .directory-tree {
            font-family: 'Courier New', monospace;
        }

        .tree-item {
            display: flex;
            align-items: center;
            padding: 0.25rem;
            cursor: pointer;
            border-radius: 0.25rem;
            margin-bottom: 2px;
        }

        .tree-item:hover {
            background-color: #e9ecef;
        }

        .tree-item.active {
            background-color: #cfe2ff;
        }

        .tree-toggle {
            width: 16px;
            margin-right: 0.25rem;
            cursor: pointer;
        }

        .tree-label {
            margin-left: 0.5rem;
            font-size: 0.9rem;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 1rem;
        }

        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding: 1rem;
            background-color: white;
            border-radius: 0.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }

        .breadcrumb-container {
            flex: 1;
        }

        .breadcrumb {
            margin: 0;
            background-color: transparent;
        }

        .toolbar-actions {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .file-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 1rem;
            padding: 1rem;
            background-color: white;
            border-radius: 0.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            overflow-y: auto;
            flex: 1;
        }

        .file-item {
            position: relative;
            padding: 1rem;
            text-align: center;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 2px solid transparent;
        }

        .file-item:hover {
            background-color: #f8f9fa;
            transform: translateY(-2px);
            border-color: #007bff;
        }

        .file-item.selected {
            background-color: #cfe2ff;
            border-color: #007bff;
        }

        .file-icon {
            margin-bottom: 0.5rem;
        }

        .file-name {
            font-weight: 500;
            margin-bottom: 0.25rem;
            word-break: break-word;
            font-size: 0.9rem;
        }

        .file-size,
        .file-date {
            font-size: 0.75rem;
            color: #6c757d;
            margin-bottom: 0.25rem;
        }

        .file-actions {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .file-item:hover .file-actions {
            opacity: 1;
        }

        .file-actions .btn {
            margin-left: 0.25rem;
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 3rem;
            color: #6c757d;
        }

        .file-list {
            background-color: white;
            border-radius: 0.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            flex: 1;
            overflow-y: auto;
        }

        .file-list table {
            margin: 0;
        }

        .file-list th {
            border-top: none;
            background-color: #f8f9fa;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .progress {
            height: 8px;
            margin-top: 1rem;
        }

        @media (max-width: 768px) {
            .file-explorer-container {
                flex-direction: column;
                height: auto;
            }

            .sidebar {
                width: 100%;
                height: 200px;
                border-right: none;
                border-bottom: 1px solid #dee2e6;
            }

            .file-grid {
                grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
                gap: 0.5rem;
            }

            .toolbar {
                flex-direction: column;
                gap: 1rem;
            }

            .toolbar-actions {
                justify-content: center;
            }
        }
    </style>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
</head>

<body>
    <%= yield %>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // View toggle functionality
            const viewToggleBtns = document.querySelectorAll('.view-toggle button');
            const fileGrid = document.getElementById('file-grid');
            const fileList = document.getElementById('file-list');

            viewToggleBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    viewToggleBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');

                    const view = this.dataset.view;
                    if (view === 'grid') {
                        fileGrid.classList.remove('d-none');
                        fileList.classList.add('d-none');
                    } else {
                        fileGrid.classList.add('d-none');
                        fileList.classList.remove('d-none');
                        populateListView();
                    }
                });
            });

            // File selection
            const fileItems = document.querySelectorAll('.file-item');
            fileItems.forEach(item => {
                item.addEventListener('click', function(e) {
                    if (e.target.closest('.file-actions')) return;

                    // Remove previous selection
                    fileItems.forEach(i => i.classList.remove('selected'));
                    // Add selection to current item
                    this.classList.add('selected');
                });

                // Double click to navigate
                item.addEventListener('dblclick', function() {
                    if (this.classList.contains('folder')) {
                        const path = this.dataset.path;
                        window.location.href = `/?path=${encodeURIComponent(path)}`;
                    }
                });
            });

            // Upload modal
            const uploadBtn = document.getElementById('upload-file');
            const uploadModal = new bootstrap.Modal(document.getElementById('uploadModal'));
            const uploadSubmit = document.getElementById('upload-submit');

            uploadBtn.addEventListener('click', () => uploadModal.show());

            uploadSubmit.addEventListener('click', function() {
                const form = document.getElementById('upload-form');
                const formData = new FormData(form);
                const progressBar = document.querySelector('#upload-progress .progress-bar');
                const progressContainer = document.getElementById('upload-progress');

                progressContainer.classList.remove('d-none');

                fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            uploadModal.hide();
                            location.reload();
                        }
                    })
                    .catch(error => {
                        console.error('Upload error:', error);
                    });
            });

            // Create folder modal
            const createFolderBtn = document.getElementById('create-folder');
            const createFolderModal = new bootstrap.Modal(document.getElementById('createFolderModal'));
            const folderSubmit = document.getElementById('folder-submit');

            createFolderBtn.addEventListener('click', () => createFolderModal.show());

            folderSubmit.addEventListener('click', function() {
                const form = document.getElementById('folder-form');
                const formData = new FormData(form);

                fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            createFolderModal.hide();
                            location.reload();
                        }
                    });
            });

            // Directory tree toggle
            document.addEventListener('click', function(e) {
                if (e.target.closest('.tree-toggle')) {
                    const toggle = e.target.closest('.tree-toggle');
                    const icon = toggle.querySelector('i');

                    if (icon.classList.contains('fa-chevron-right')) {
                        icon.classList.remove('fa-chevron-right');
                        icon.classList.add('fa-chevron-down');
                        // Load subdirectories here
                    } else {
                        icon.classList.remove('fa-chevron-down');
                        icon.classList.add('fa-chevron-right');
                    }
                }
            });

            function populateListView() {
                const tbody = document.querySelector('#file-list tbody');
                tbody.innerHTML = '';

                fileItems.forEach(item => {
                    const name = item.querySelector('.file-name').textContent;
                    const size = item.querySelector('.file-size')?.textContent || '-';
                    const date = item.querySelector('.file-date')?.textContent || '-';
                    const isFolder = item.classList.contains('folder');

                    const row = document.createElement('tr');
                    row.innerHTML = `
              <td>
                <i class="fas fa-${isFolder ? 'folder text-warning' : 'file text-muted'} me-2"></i>
                ${name}
              </td>
              <td>${size}</td>
              <td>${date}</td>
              <td>
                <button class="btn btn-sm btn-outline-primary me-1" title="Download">
                  <i class="fas fa-download"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger" title="Delete">
                  <i class="fas fa-trash"></i>
                </button>
              </td>
            `;
                    tbody.appendChild(row);
                });
            }
        });
    </script>
</body>

</html>